<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QuarthCloob</title>
    <style>
        * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* Основной контейнер страницы */
body, html {
  height: 100%;
  font-family: 'Arial', sans-serif;
  overflow: hidden; /* Убираем полосы прокрутки */
  color: white; /* Общий цвет текста */
}

/* Переливающийся фон с глубиной */
body {
  background: linear-gradient(
    45deg,
    #800080, /* Фиолетовый */
    #9400D3, /* Тёмно-фиолетовый */
    #000000 /* Чёрный */
  );
  animation: animateBackground 10s linear infinite;
  min-height: 100vh;
  position: relative;
}

/* Анимация движения градиента */
@keyframes animateBackground {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 100% 50%;
  }
}

/* Основной контейнер с отступами и тенью */
.container {
  position: relative;
  width: 90%;
  max-width: 1200px; /* Ограничиваем максимальную ширину */
  margin: 0 auto; /* Центрируем */
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  padding: 20px;
  border-radius: 15px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5); /* Объёмная тень */
  background: rgba(0, 0, 0, 0.7); /* Полупрозрачный фон контейнера */
}

/* Контейнер для заголовка и слогана (с отступами) */
.header-container {
  text-align: center;
  margin-bottom: 40px;
  width: 100%;
}

/* Контейнер для кнопки (с отступами и выравниванием) */
.button-container {
  text-align: center;
  width: 100%;
}

/* Заголовок с эффектом свечения */
.welcome-text {
  font-size: 3.5em;
  font-weight: 900;
  text-align: center;
  margin-bottom: 20px;
  text-shadow:
    0 0 5px rgba(255, 255, 255, 0.5),
    0 0 10px rgba(255, 255, 255, 0.5),
    0 0 20px rgba(128, 0, 128, 1),
    0 0 30px rgba(128, 0, 128, 1),
    0 0 40px rgba(128, 0, 128, 0.8);
  animation: glow 1.5s ease-in-out infinite alternate;
}

/* Анимация свечения заголовка */
@keyframes glow {
  from {
    text-shadow:
      0 0 5px rgba(255, 255, 255, 0.5),
      0 0 10px rgba(255, 255, 255, 0.5),
      0 0 20px rgba(128, 0, 128, 0.8),
      0 0 30px rgba(128, 0, 128, 0.8),
      0 0 40px rgba(128, 0, 128, 0.6);
  }
  to {
    text-shadow:
      0 0 5px rgba(255, 255, 255, 0.8),
      0 0 10px rgba(255, 255, 255, 0.8),
      0 0 20px rgba(128, 0, 128, 1),
      0 0 30px rgba(128, 0, 128, 1),
      0 0 40px rgba(128, 0, 128, 0.9);
  }
}

/* Подзаголовок с мягким стилем */
.subtitle {
  color: #cccccc;
  font-size: 1.4em;
  text-align: center;
  margin-bottom: 50px;
  opacity: 0.8;
  letter-spacing: 1px;
  font-style: italic;
}

/* Кнопка с объёмным эффектом и градиентом */
.play-button {
  background: linear-gradient(45deg, #800080, #9400D3);
  color: white;
  padding: 18px 35px;
  border: none;
  border-radius: 10px;
  font-size: 1.2em;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 8px 15px rgba(0, 0, 0, 0.3), 0 3px 8px rgba(128, 0, 128, 0.5);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  outline: none;
}

/* Эффект наведения на кнопку (с углублением) */
.play-button:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 20px rgba(0, 0, 0, 0.4), 0 6px 15px rgba(128, 0, 128, 0.6);
  background: linear-gradient(45deg, #9400D3, #800080);
}

/* Верхняя и нижняя полосы с градиентом */
.top-bar, .bottom-bar {
  background: linear-gradient(90deg, #800080, #9400D3, #000000);
  height: 40px;
  width: 100%;
  position: fixed;
  z-index: 1000;
}

.top-bar {
  top: 0;
}

.bottom-bar {
  bottom: 0;
}

/* Секция с дополнительной информацией (можно добавить позже) */
.info-container {
  margin-top: 30px;
  padding: 20px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 10px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);
  text-align: center;
}

/* Адаптивная версия (для мобильных устройств) */
@media (max-width: 768px) {
  .welcome-text {
    font-size: 2.5em;
  }
  .subtitle {
    font-size: 1.1em;
    margin-bottom: 30px;
  }
  .play-button {
    padding: 12px 25px;
    font-size: 1em;
  }
  .container {
    padding: 10px;
  }
}

/* Для очень маленьких экранов */
@media (max-width: 480px) {
  .welcome-text {
    font-size: 2em;
  }
  .subtitle {
    font-size: 1em;
  }
}
/* Контейнер для разделов */
.sections-container {
  display: flex;
  flex-wrap: wrap; /* Позволяем элементам переноситься на новую строку */
  justify-content: space-around; /* Равномерное распределение отступов */
  margin-top: 40px; /* Отступ от кнопки */
  width: 100%;
}

/* Общий стиль для каждого раздела */
.section-item {
  background: rgba(0, 0, 0, 0.7); /* Полупрозрачный тёмный фон */
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
  width: calc(33% - 20px); /* Три элемента в ряд */
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
  transition: all 0.3s ease;
  text-align: center;
  min-width: 250px; /* Минимальная ширина для мобильных */
}

/* Стили для заголовков разделов */
.section-item h2 {
  color: #f5f2f5;
  font-size: 1.8em;
  margin-bottom: 15px;
  text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}

/* Стили для текста разделов */
.section-item p {
  color: #cccccc;
  line-height: 1.6;
  font-size: 1em;
}

/* Эффект наведения на разделы */
.section-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
  background: rgba(0, 0, 0, 0.8);
}

/* Адаптация для мобильных устройств */
@media (max-width: 768px) {
  .section-item {
    width: 100%; /* На мобильных — один столбец */
    margin-bottom: 15px;
  }
}

/* Дополнительные стили для отдельных разделов (если нужно выделить) */
#main { background-color: rgba(128, 0, 128, 0.7); }
#server { background-color: rgba(100, 0, 100, 0.7); }
#shop { background-color: rgba(140, 0, 140, 0.7); }
#forum { background-color: rgba(110, 0, 110, 0.7); }
#support { background-color: rgba(90, 0, 90, 0.7); }
    </style>
</head>
  <header class="header">
        <div class="container">
            <div class="logo">
                <h1>QuarthCloob</h1>
            </div>
            <nav class="nav">
               <div class="sections-container">
  <div class="section-item" id="main">
    <h2>Главный</h2>
    <p>Здесь находится основная информация о проекте QuarthCloob. Узнайте больше о наших приключениях!</p>
  </div>
  <div class="section-item" id="server">
    <h2>Сервер</h2>
    <p>Информация о нашем игровом сервере: , QuarthCloob.net , правила, актуальные обновления.</p>
  </div>
  <div class="section-item" id="shop">
    <h2>Магазин</h2>
    <p>Приобретайте внутриигровые предметы, скины и бонусы. Безопасные транзакции!</p>
  </div>
  <div class="section-item" id="forum">
    <h2>Форум</h2>
    <p>Общайтесь с другими игроками, создавайте темы, делитесь опытом и советами.</p>
  </div>
  <div class="section-item" id="support">
    <h2>Поддержка</h2>
    <p>Нужна помощь? Задайте вопрос нашей службе поддержки — ответим в кратчайшие сроки!</p>
  </div>
</div>
            </nav>
        </div>
    </header>

    <!-- Основной контент -->
    <main class="main">
        <!-- Герой-секция -->
        <section class="hero">
            <div class="container">
                <h2>Добро пожаловать в QuarthCloob!</h2>
                <p>Погрузись в мир приключений и возможностей!</p>
                <a href="#" class="btn">Играть сейчас</a>
            </div>
        </section>

        <!-- Информация о сервере -->
        <section class="server-info">
            <div class="container">
                <h3>О нашем сервере</h3>
                <div class="features">
                    <div class="feature">
                        <h4>Уникальные моды</h4>
                        <p>Мы предлагаем кастомные моды, которых нет на других серверах.</p>
                    </div>
                    <div class="feature">
                        <h4>Дружное сообщество</h4>
                        <p>Присоединяйся к активному и дружелюбному сообществу игроков.</p>
                    </div>
                    <div class="feature">
                        <h4>Регулярные ивенты</h4>
                        <p>Участвуй в еженедельных событиях с ценными призами!</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!--Подвал сайта-->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 QuarthCloob. Все права защищены.</p>
        </div>
    </footer>
</body>
</html>
